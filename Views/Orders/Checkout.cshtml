@model CheckoutVm
@{
    ViewData["Title"] = "Checkout";
    var cart = ViewBag.Cart as IEnumerable<CartItem> ?? Enumerable.Empty<CartItem>();
    var subtotal = (decimal)(ViewBag.Subtotal ?? 0m);
    var shipping = (decimal)(ViewBag.Shipping ?? 0m);
    var shippingZone = ViewBag.ShippingZone as string;
}

<div class="section-head">
    <div>
        <h2>Checkout</h2>
        <p class="lead">Confirm your shipping details and choose a payment method.</p>
    </div>
    <a asp-controller="Cart" asp-action="Index" class="btn btn-outline">← Back to cart</a>
</div>

<div class="steps">
    <span class="step-pill done">1 · Cart</span>
    <span class="step-pill active">2 · Shipping & payment</span>
    <span class="step-pill">3 · Track order</span>
</div>

<form asp-action="Checkout" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div class="grid-3">
        <div class="card"><div class="card-body">
            <h3 class="mt-0">Shipping details</h3>
            <div class="alert alert-info mb-2" style="background:#eef2ff;border-left:4px solid #6366f1;padding:.75rem 1rem;border-radius:.4rem;">
                <strong>📍 Delivery: Luzon only.</strong>
                <span class="text-muted" style="font-size:.9rem;">Ships from Karangalan Village, Brgy. San Isidro, Cainta, Rizal via LBC. Shipping fee is based on LBC's standard small-parcel rate card and your destination province.</span>
            </div>
            <div asp-validation-summary="ModelOnly" class="alert alert-error mb-2" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

            <div class="row-2">
                <div class="form-group">
                    <label class="form-label">Recipient name</label>
                    <input asp-for="ShippingName" class="form-control" />
                    <span asp-validation-for="ShippingName" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Phone</label>
                    <input asp-for="ShippingPhone" class="form-control"
                           type="tel"
                           inputmode="numeric"
                           maxlength="13"
                           pattern="(09|\+639|639)\d{9}"
                           title="Philippine mobile number (e.g. 09171234567 or +639171234567)."
                           placeholder="09171234567"
                           oninput="this.value=this.value.replace(/[^\d+]/g,'')" />
                    <small class="form-text">Digits only. Format: 09XXXXXXXXX or +639XXXXXXXXX</small>
                    <span asp-validation-for="ShippingPhone" class="text-danger"></span>
                </div>
            </div>

            <div class="row-2">
                <div class="form-group">
                    <label class="form-label">Province</label>
                    <select asp-for="ShippingProvince" id="Province" class="form-control"
                            data-province="true" data-city-target="City"
                            data-preset="@Model.ShippingProvince"></select>
                    <small id="zoneHint" class="form-text" style="color:var(--ac-purple);">@(string.IsNullOrEmpty(shippingZone) ? "Select your province to see the shipping fee." : $"Zone: {shippingZone}")</small>
                    <span asp-validation-for="ShippingProvince" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">City / Municipality</label>
                    <select asp-for="ShippingCity" id="City" class="form-control" data-preset="@Model.ShippingCity">
                        <option value="">Select city…</option>
                    </select>
                </div>
            </div>
            <div class="row-3">
                <div class="form-group">
                    <label class="form-label">Barangay</label>
                    <input asp-for="ShippingBarangay" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label">Street / House no.</label>
                    <input asp-for="ShippingStreet" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label">Postal code</label>
                    <input asp-for="ShippingPostalCode" class="form-control" />
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Order note (optional)</label>
                <textarea asp-for="Notes" class="form-control" placeholder="Landmarks, preferred delivery time, etc."></textarea>
            </div>

            <h3 class="mt-3">Payment method</h3>
            <div class="pay-options">
                <label>
                    <input type="radio" asp-for="PaymentMethod" value="GCash" checked />
                    <img src="~/images/Gcash.png" alt="GCash" class="pay-icon pay-icon-img" />
                    <div class="pay-label">
                        <strong>GCash</strong><br/>
                        <small class="text-muted">Pay now, enter reference</small>
                    </div>
                </label>
                <label>
                    <input type="radio" asp-for="PaymentMethod" value="PayMaya" />
                    <img src="~/images/Paymaya.png" alt="Maya" class="pay-icon pay-icon-img" />
                    <div class="pay-label">
                        <strong>PayMaya / Maya</strong><br/>
                        <small class="text-muted">Pay now, enter reference</small>
                    </div>
                </label>
                <label>
                    <input type="radio" asp-for="PaymentMethod" value="COD" />
                    <img src="~/images/COD.png" alt="Cash on Delivery" class="pay-icon pay-icon-img" />
                    <div class="pay-label">
                        <strong>Cash on Delivery</strong><br/>
                        <small class="text-muted">Pay the courier in cash</small>
                    </div>
                </label>
            </div>

            <div id="gcashPanel" class="payPanel mt-2">
                <div class="card pay-note pay-note-gcash"><div class="card-body">
                    <strong>GCash instructions</strong>
                    <p class="text-muted mt-1 mb-1">Send the total amount to <strong>0917-123-4567 (AliCraft)</strong>, then enter your GCash reference number and/or upload a screenshot below.</p>
                </div></div>
                <div class="row-2 mt-2">
                    <div class="form-group">
                        <label class="form-label">GCash reference #</label>
                        <input name="PaymentReference" id="GCashRef" class="form-control" placeholder="e.g. 1234567890" value="@Model.PaymentReference" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Payment screenshot</label>
                        <input name="PaymentProof" id="GCashProof" type="file" class="form-control" accept="image/*" />
                    </div>
                </div>
            </div>

            <div id="paymayaPanel" class="payPanel mt-2" style="display:none;">
                <div class="card pay-note pay-note-maya"><div class="card-body">
                    <strong>PayMaya / Maya instructions</strong>
                    <p class="text-muted mt-1 mb-1">Send the total amount to Maya <strong>0917-987-6543 (AliCraft)</strong>, then enter your Maya reference number and/or upload a screenshot below.</p>
                </div></div>
                <div class="row-2 mt-2">
                    <div class="form-group">
                        <label class="form-label">Maya reference #</label>
                        <input name="PaymentReference" id="PayMayaRef" class="form-control" placeholder="e.g. M-0001234567" disabled />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Payment screenshot</label>
                        <input name="PaymentProof" id="PayMayaProof" type="file" class="form-control" accept="image/*" disabled />
                    </div>
                </div>
            </div>

            <div id="codPanel" class="payPanel mt-2" style="display:none;">
                <div class="card pay-note pay-note-cod"><div class="card-body">
                    <strong>Cash on Delivery</strong>
                    <p class="text-muted mt-1 mb-0">Pay the rider in cash on delivery. Please prepare the exact amount when possible.</p>
                </div></div>
            </div>
        </div></div>

        <div class="card"><div class="card-body">
            <h3 class="mt-0">Order summary</h3>
            @foreach (var c in cart)
            {
                <div class="flex-between mb-1">
                    <span>
                        <strong>@c.Product?.Name</strong><br/>
                        <small class="text-muted">₱@((c.Product?.Price ?? 0).ToString("N2")) × @c.Quantity</small>
                    </span>
                    <span>₱@(((c.Product?.Price ?? 0) * c.Quantity).ToString("N2"))</span>
                </div>
            }
            <hr/>
            <div class="flex-between"><span>Subtotal</span><strong id="sumSubtotal" data-value="@subtotal">₱@subtotal.ToString("N2")</strong></div>
            <div class="flex-between">
                <span>Shipping <small id="sumZone" class="text-muted" style="font-weight:normal;">@(string.IsNullOrEmpty(shippingZone) ? "" : $"({shippingZone})")</small></span>
                <strong id="sumShipping" data-value="@shipping">₱@shipping.ToString("N2")</strong>
            </div>
            <div class="flex-between mt-1"><span style="font-size:1.1rem;">Total</span><strong id="sumTotal" style="color:var(--ac-pink);font-size:1.3rem;">₱@((subtotal + shipping).ToString("N2"))</strong></div>
            <button type="submit" class="btn btn-primary btn-lg btn-block mt-2">Place order</button>
            <p class="text-muted text-center mt-1 mb-0" style="font-size:.82rem;">By placing this order you agree to our customization terms.</p>
        </div></div>
    </div>
</form>

@section Scripts {
<script>
    // Toggle the payment panel for the selected method.
    // Only inputs in the active panel are enabled, so only one PaymentReference/PaymentProof
    // is submitted with the form.
    (function () {
        var panels = {
            'GCash':   { panel: 'gcashPanel',   ref: 'GCashRef',   proof: 'GCashProof' },
            'PayMaya': { panel: 'paymayaPanel', ref: 'PayMayaRef', proof: 'PayMayaProof' },
            'COD':     { panel: 'codPanel',     ref: null,         proof: null }
        };
        function togglePay() {
            var selected = (document.querySelector('input[name="PaymentMethod"]:checked') || {}).value || 'GCash';
            Object.keys(panels).forEach(function (key) {
                var info = panels[key];
                var on = key === selected;
                var el = document.getElementById(info.panel);
                if (el) el.style.display = on ? 'block' : 'none';
                if (info.ref)   document.getElementById(info.ref).disabled   = !on;
                if (info.proof) document.getElementById(info.proof).disabled = !on;
            });
        }
        document.querySelectorAll('input[name="PaymentMethod"]').forEach(function (r) {
            r.addEventListener('change', togglePay);
        });
        togglePay();
    })();

    // Live-update shipping fee when the user changes their province.
    // Hits /api/locations/shipping-fee and rewrites the order-summary numbers.
    (function () {
        var prov     = document.getElementById('Province');
        var sumShip  = document.getElementById('sumShipping');
        var sumZone  = document.getElementById('sumZone');
        var sumSub   = document.getElementById('sumSubtotal');
        var sumTotal = document.getElementById('sumTotal');
        var hint     = document.getElementById('zoneHint');
        if (!prov || !sumShip || !sumTotal) return;

        function fmt(n) {
            return '₱' + Number(n).toLocaleString('en-PH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }
        function refresh() {
            var p = prov.value;
            if (!p) {
                if (hint) { hint.textContent = 'Select your province to see the shipping fee.'; hint.style.color = ''; }
                return;
            }
            fetch('/api/locations/shipping-fee?province=' + encodeURIComponent(p))
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    var subtotal = parseFloat(sumSub.getAttribute('data-value')) || 0;
                    if (data.serviceable) {
                        var fee = Number(data.fee);
                        sumShip.textContent = fmt(fee);
                        sumShip.setAttribute('data-value', fee);
                        if (sumZone) sumZone.textContent = '(' + data.zone + ')';
                        sumTotal.textContent = fmt(subtotal + fee);
                        if (hint) {
                            hint.textContent = 'Zone: ' + data.zone + ' — shipping ' + fmt(fee);
                            hint.style.color = '';
                        }
                    } else {
                        sumShip.textContent = '—';
                        sumShip.setAttribute('data-value', 0);
                        if (sumZone) sumZone.textContent = '(not serviceable)';
                        sumTotal.textContent = fmt(subtotal);
                        if (hint) {
                            hint.textContent = '⚠ We don\'t deliver to ' + p + '. Please choose a Luzon province.';
                            hint.style.color = '#dc2626';
                        }
                    }
                })
                .catch(function () { /* ignore network glitches */ });
        }
        prov.addEventListener('change', refresh);
        // No initial-load call: the server already rendered the correct fee/zone
        // for the user's saved province, and the provinces dropdown is populated
        // asynchronously by site.js (so prov.value would still be empty here).
    })();
</script>
}
