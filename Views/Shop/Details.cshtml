@model Product
@inject CurrentUser CurrentUser
@{
    ViewData["Title"] = Model.Name;
}

<a asp-action="Index" class="text-muted">← Back to shop</a>

<div class="grid-3 mt-2">
    <div class="card"><div class="card-body" style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:start;">
        <div>
            <div class="product" style="border:0;box-shadow:none;">
                <div class="thumb" style="border-radius:12px;">
                    <span class="category-tag">@Model.Category</span>
                    <img src="@(string.IsNullOrEmpty(Model.ImagePath) ? "/images/placeholder-frame.svg" : Model.ImagePath)" alt="@Model.Name" />
                </div>
            </div>
        </div>
        <div>
            <h1 class="mt-0">@Model.Name</h1>
            <div class="price" style="color:var(--ac-pink);font-size:2rem;font-weight:800;">₱@Model.Price.ToString("N2")</div>
            <p class="text-muted">@Model.Description</p>
            <p><strong>Stock:</strong> @Model.Stock piece(s) available</p>

            @if (CurrentUser.IsAuthenticated && !CurrentUser.IsAdmin)
            {
                <form asp-controller="Cart" asp-action="Add" method="post" enctype="multipart/form-data" class="mt-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <div class="row-2">
                        <div class="form-group">
                            <label class="form-label">Quantity</label>
                            <input type="number" name="quantity" value="1" min="1" max="@Math.Max(1, Model.Stock)" class="form-control" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Your photo (optional)</label>
                            <input type="file" name="customImage" accept="image/*" class="form-control" />
                            <div class="form-text">Attach a photo to personalize this lithophane.</div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Customization note (optional)</label>
                        <textarea name="customNote" class="form-control" placeholder="Tell us how you'd like this customized…"></textarea>
                    </div>
                    <div class="flex gap-1">
                        <button type="submit" class="btn btn-primary btn-lg">Add to Cart</button>
                        <a asp-controller="Chat" asp-action="Index" class="btn btn-outline btn-lg">💬 Chat first</a>
                    </div>
                </form>
            }
            else if (CurrentUser.IsAdmin)
            {
                <div class="alert alert-info">You're logged in as admin. Switch to a customer account to place orders.</div>
            }
            else
            {
                <div class="alert alert-info">Please <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path">log in</a> to buy this item or chat with our craftsman.</div>
                <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@Context.Request.Path" class="btn btn-primary btn-lg">Login to Buy</a>
            }
        </div>
    </div></div>

    <div class="card"><div class="card-body">
        <h3 class="mt-0">Need custom details?</h3>
        <p class="text-muted">Chat directly with our craftsman to discuss size, lighting, or special requests. We reply in minutes during business hours.</p>
        <a asp-controller="Chat" asp-action="Index" class="btn btn-warm btn-block">Open chat</a>

        <h3 class="mt-3">Shipping & payment</h3>
        <ul class="text-muted" style="padding-left:1.2rem;">
            <li>LBC shipping ₱90–₱180 (Luzon only)</li>
            <li>GCash, PayMaya, or Cash on Delivery</li>
            <li>Track: Pending → Processing → In Transit → Delivered</li>
        </ul>
    </div></div>
</div>
