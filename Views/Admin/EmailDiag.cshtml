@using Alicraft2.Services
@{
    ViewData["Title"] = "Email diagnostics";
    var diag = (EmailDiagnostics)ViewBag.Diag;
    var testResult = ViewBag.TestResult as string;
    var testOk = (bool)(ViewBag.TestOk ?? false);
    var testRecipient = ViewBag.TestRecipient as string ?? "";
}

<div class="section-head">
    <div>
        <h2>Email diagnostics</h2>
        <p class="lead">Live SMTP configuration and test send. Admin only.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline">← Back to dashboard</a>
</div>

<div class="card">
    <div class="card-body">
        <h3 class="mt-0">SMTP status</h3>
        <p>
            @if (diag.IsRealSendConfigured)
            {
                <span style="background:#16a34a;color:#fff;padding:4px 10px;border-radius:6px;font-weight:700;">CONFIGURED</span>
                <small class="text-muted">— the app will attempt to send real emails.</small>
            }
            else
            {
                <span style="background:#dc2626;color:#fff;padding:4px 10px;border-radius:6px;font-weight:700;">NOT CONFIGURED</span>
                <small class="text-muted">— emails will only be logged. Missing: <code>@diag.MissingFields</code></small>
            }
        </p>

        <table class="table" style="margin-top:1rem;">
            <tbody>
                <tr><th style="width:200px;">Smtp__Host</th><td><code>@diag.Host</code></td></tr>
                <tr><th>Smtp__Port</th><td><code>@diag.Port</code></td></tr>
                <tr><th>Smtp__EnableSsl</th><td><code>@diag.EnableSsl</code></td></tr>
                <tr><th>Smtp__Username</th><td><code>@diag.Username</code></td></tr>
                <tr><th>Smtp__Password</th><td><code>@diag.PasswordStatus</code></td></tr>
                <tr><th>Smtp__FromEmail</th><td><code>@diag.FromEmail</code></td></tr>
                <tr><th>Smtp__FromName</th><td><code>@diag.FromName</code></td></tr>
                <tr><th>Smtp__BaseUrl</th><td><code>@diag.BaseUrl</code></td></tr>
            </tbody>
        </table>
        <p class="text-muted" style="font-size:.85rem;margin-top:1rem;">
            Username and FromEmail are masked for safety. The password is never displayed — only its length is shown.
        </p>
    </div>
</div>

<div class="card mt-3">
    <div class="card-body">
        <h3 class="mt-0">Send a test email</h3>
        <p class="text-muted">Sends a real email through the live SMTP settings to whatever address you enter and shows the result inline.</p>

        @if (!string.IsNullOrEmpty(testResult))
        {
            <div class="alert @(testOk ? "alert-success" : "alert-danger")" style="margin:1rem 0;">
                <strong>@(testOk ? "Success" : "Failed")</strong> — @testResult
            </div>
        }

        <form asp-action="EmailDiagSend" method="post" class="flex gap-1" style="max-width:560px;">
            @Html.AntiForgeryToken()
            <input type="email" name="recipient" value="@testRecipient" placeholder="recipient@example.com" required class="form-control" />
            <button type="submit" class="btn btn-primary">Send test email</button>
        </form>
    </div>
</div>
