@model Order
@{
    ViewData["Title"] = "Order " + Model.OrderNumber;
    string[] options = { OrderStatus.Pending, OrderStatus.Processing, OrderStatus.InTransit, OrderStatus.Delivered, OrderStatus.Cancelled };
}

<a asp-action="Orders" class="text-muted">← All orders</a>

<div class="section-head mt-1">
    <div>
        <h2>Order @Model.OrderNumber</h2>
        <p class="lead">Customer: <strong>@Model.User?.Name</strong> (@Model.User?.Email)</p>
    </div>
    <a asp-controller="Chat" asp-action="Thread" asp-route-userId="@Model.UserId" class="btn btn-warm">💬 Chat with customer</a>
</div>

@await Html.PartialAsync("/Views/Orders/_Tracker.cshtml", Model)

<div class="grid-3 mt-3">
    <div class="card"><div class="card-body">
        <h3 class="mt-0">Update status</h3>
        <form asp-action="UpdateOrderStatus" method="post" class="flex gap-1">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <select name="status" class="form-control">
                @foreach (var opt in options)
                {
                    <option value="@opt" selected="@(Model.Status == opt ? "selected" : null)">@(opt == OrderStatus.InTransit ? "In Transit" : opt)</option>
                }
            </select>
            <button type="submit" class="btn btn-primary">Update</button>
        </form>

        <h3 class="mt-3">Items</h3>
        <table class="table">
            <thead><tr><th>Product</th><th>Qty</th><th>Price</th><th>Subtotal</th></tr></thead>
            <tbody>
            @foreach (var i in Model.Items)
            {
                <tr>
                    <td>
                        <strong>@i.ProductName</strong>
                        @if (!string.IsNullOrEmpty(i.CustomNote)) { <div class="text-muted" style="font-size:.82rem;">📝 @i.CustomNote</div> }
                        @if (!string.IsNullOrEmpty(i.CustomImagePath)) { <a href="@i.CustomImagePath" target="_blank" class="text-muted" style="font-size:.82rem;">🖼 custom photo</a> }
                    </td>
                    <td>@i.Quantity</td>
                    <td>₱@i.UnitPrice.ToString("N2")</td>
                    <td>₱@((i.UnitPrice * i.Quantity).ToString("N2"))</td>
                </tr>
            }
            </tbody>
        </table>
        <div class="flex-between"><span>Subtotal</span><strong>₱@Model.Subtotal.ToString("N2")</strong></div>
        <div class="flex-between"><span>Shipping</span><strong>₱@Model.Shipping.ToString("N2")</strong></div>
        <div class="flex-between mt-1"><span style="font-size:1.1rem;">Total</span><strong style="color:var(--ac-pink);font-size:1.25rem;">₱@Model.Total.ToString("N2")</strong></div>
    </div></div>

    <div class="card"><div class="card-body">
        <h3 class="mt-0">Shipping</h3>
        <p>
            <strong>@Model.ShippingName</strong><br/>
            @Model.ShippingPhone<br/>
            @Model.ShippingStreet, @Model.ShippingBarangay<br/>
            @Model.ShippingCity, @Model.ShippingProvince @Model.ShippingPostalCode
        </p>
        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <p><strong>Note:</strong> @Model.Notes</p>
        }

        <h3 class="mt-3">Payment</h3>
        <p class="mb-0"><strong>@Model.PaymentMethod</strong></p>
        @if (!string.IsNullOrEmpty(Model.PaymentReference))
        {
            <p class="text-muted mb-0">Ref: @Model.PaymentReference</p>
        }
        @if (!string.IsNullOrEmpty(Model.PaymentProofPath))
        {
            <a href="@Model.PaymentProofPath" target="_blank">
                <img src="@Model.PaymentProofPath" alt="payment proof" style="max-width:100%;border-radius:10px;margin-top:.5rem;" />
            </a>
        }
    </div></div>
</div>
