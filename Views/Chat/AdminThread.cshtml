@model IEnumerable<ChatMessage>
@inject CurrentUser CurrentUser
@{
    var threadUser = ViewBag.ThreadUser as User;
    ViewData["Title"] = "Chat · " + (threadUser?.Name ?? "Customer");
    ViewBag.LayoutFull = true;
    var myId = CurrentUser.Id;
}

<div class="chat-header">
    <div>
        <a asp-controller="Admin" asp-action="Inbox" class="text-muted" style="display:inline-block;margin-bottom:.25rem;font-size:.85rem;">← All conversations</a>
        <h2 class="m-0">@threadUser?.Name</h2>
        <small class="text-muted">@threadUser?.Email · @threadUser?.Phone</small>
    </div>
</div>

<div class="chat" id="chat" data-endpoint="/Chat/Poll?userId=@threadUser?.Id">
    <div class="chat-messages" id="chatMessages">
        @foreach (var m in Model)
        {
            var me = m.SenderRole == "Admin";
            <div class="chat-row @(me ? "me" : "")" data-id="@m.Id">
                <div class="bubble-wrap">
                    @* Keep bubble contents on a single Razor line to avoid rendering template indentation inside the bubble. *@
                    <div class="bubble">@(m.Body ?? "")@if (!string.IsNullOrEmpty(m.ImagePath)) {<a href="@m.ImagePath" target="_blank"><img src="@m.ImagePath" alt="attachment" /></a>}</div>
                    <div class="meta">@m.CreatedAt.ToLocalTime().ToString("MMM d · h:mm tt")</div>
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <div class="text-center text-muted mt-3" id="emptyHint">
                No messages yet with this customer.
            </div>
        }
    </div>

    <form asp-controller="Chat" asp-action="Send" method="post" enctype="multipart/form-data" class="chat-input" id="chatForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="userId" value="@threadUser?.Id" />
        <label class="icon-btn" title="Attach image" for="chatImage">📎</label>
        <input id="chatImage" type="file" name="image" accept="image/*" />
        <div id="chatAttachChip" class="chat-attach-chip" hidden>
            <img id="chatAttachThumb" class="thumb" src="" alt="" />
            <span id="chatAttachName" class="name"></span>
            <button type="button" id="chatAttachRemove" class="remove" aria-label="Remove attachment" title="Remove">×</button>
        </div>
        <textarea name="body" id="chatBody" class="form-control" placeholder="Reply to customer…" rows="1"></textarea>
        <button type="submit" class="btn btn-primary">Send</button>
    </form>
</div>

@section Scripts {
<script>
    (function () {
        var box = document.getElementById('chatMessages');
        var chat = document.getElementById('chat');
        var endpoint = chat.getAttribute('data-endpoint');
        function scrollBottom() { box.scrollTop = box.scrollHeight; }
        scrollBottom();
        var last = @(Model.Any() ? new DateTimeOffset(Model.Max(m => m.CreatedAt), TimeSpan.Zero).ToUnixTimeMilliseconds() : 0);
        function poll() {
            fetch(endpoint + '&since=' + last)
                .then(function (r) { return r.json(); })
                .then(function (items) {
                    if (!items || items.length === 0) return;
                    var emptyHint = document.getElementById('emptyHint');
                    if (emptyHint) emptyHint.remove();
                    items.forEach(function (m) {
                        if (document.querySelector('[data-id="' + m.id + '"]')) return;
                        var row = document.createElement('div');
                        row.className = 'chat-row' + (m.role === 'Admin' ? ' me' : '');
                        row.setAttribute('data-id', m.id);
                        var html = '<div class="bubble-wrap"><div class="bubble">';
                        if (m.body) html += escapeHtml(m.body);
                        if (m.image) html += '<a href="' + m.image + '" target="_blank"><img src="' + m.image + '" alt="attachment"/></a>';
                        html += '</div><div class="meta">' + new Date(m.at).toLocaleString() + '</div></div>';
                        row.innerHTML = html;
                        box.appendChild(row);
                        last = Math.max(last, m.at);
                    });
                    scrollBottom();
                });
        }
        function escapeHtml(s) { return s.replace(/[&<>"']/g, function(c){ return ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]; }).replace(/\n/g, '<br/>'); }
        setInterval(poll, 2500);

        var ta = document.getElementById('chatBody');
        ta.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                document.getElementById('chatForm').submit();
            }
        });
    })();
</script>
}
