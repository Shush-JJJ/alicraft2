@model ResendVerificationResult
@{
    ViewData["Title"] = "Resend verification";
    var email = (string?)ViewBag.Email ?? "";
}

<section class="card">
    <div class="auth-shell" style="min-height:auto;">
        <div class="auth-hero">
            <img src="~/images/logo.png" alt="AliCraft" />
            <h1>Resend verification.</h1>
            <p>Get a new verification link in your inbox.</p>
        </div>
        <div class="auth-form-wrap">
            <form asp-action="ResendVerification" method="post" class="auth-form">
                @Html.AntiForgeryToken()
                <h2>Resend verification email</h2>
                <p class="lead">Enter the email you registered with and we'll send a fresh verification link.</p>

                @if (!string.IsNullOrEmpty(Model.Message))
                {
                    <div class="alert alert-success mb-2">@Model.Message</div>
                }

                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" value="@email" class="form-control" placeholder="you@email.com" required />
                </div>

                <button type="submit" class="btn btn-primary btn-lg btn-block">Send verification link</button>

                <p class="text-center mt-2 mb-0">
                    <a asp-action="Login">← Back to login</a>
                </p>
            </form>
        </div>
    </div>
</section>
