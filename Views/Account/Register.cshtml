@model RegisterVm
@{
    ViewData["Title"] = "Create account";
    Layout = "_Layout";
}

<section class="card">
    <div class="auth-shell" style="min-height:auto;">
        <div class="auth-hero">
            <img src="~/images/logo.png" alt="AliCraft" style="height:80px;margin-bottom:1rem;" />
            <h1>Join AliCraft.</h1>
            <p>Create a free account to order custom lithophanes, track your shipments, and chat with our craftsman.</p>
            <ul class="mt-2" style="line-height:1.8;">
                <li>✨ Personalized 3D crafts</li>
                <li>📦 Real-time order tracking</li>
                <li>💬 Direct chat with our team</li>
            </ul>
        </div>
        <div class="auth-form-wrap">
            <form asp-action="Register" method="post" class="auth-form">
                @Html.AntiForgeryToken()
                <h2>Create your account</h2>
                <p class="lead">Already have one? <a asp-action="Login">Log in instead</a>.</p>
                <div asp-validation-summary="ModelOnly" class="validation-summary-errors alert alert-error mb-2" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                <div class="row-2">
                    <div class="form-group">
                        <label class="form-label">Full name</label>
                        <input asp-for="Name" class="form-control" placeholder="Juan Dela Cruz" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" placeholder="you@email.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>

                <div class="row-2">
                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <input asp-for="Password" class="form-control" type="password"
                               minlength="8"
                               pattern="(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).{8,}"
                               title="At least 8 characters with one uppercase letter, one number, and one special character."
                               autocomplete="new-password" />
                        <small class="form-text">8+ chars, 1 uppercase, 1 number, 1 special character</small>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Confirm password</label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password"
                               minlength="8"
                               autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Phone number</label>
                    <input asp-for="Phone" class="form-control"
                           type="tel"
                           inputmode="numeric"
                           maxlength="13"
                           pattern="(09|\+639|639)\d{9}"
                           title="Philippine mobile number (e.g. 09171234567 or +639171234567)."
                           placeholder="09171234567"
                           oninput="this.value=this.value.replace(/[^\d+]/g,'')" />
                    <small class="form-text">Digits only. Format: 09XXXXXXXXX or +639XXXXXXXXX</small>
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <h3 class="mt-2 mb-1" style="font-size:1rem;">Delivery address</h3>

                <div class="row-2">
                    <div class="form-group">
                        <label class="form-label">Province</label>
                        <select asp-for="Province" id="Province" class="form-control"
                                data-province="true" data-city-target="City"></select>
                        <span asp-validation-for="Province" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label class="form-label">City / Municipality</label>
                        <select asp-for="City" id="City" class="form-control" data-preset="@Model.City">
                            <option value="">Select city…</option>
                        </select>
                        <span asp-validation-for="City" class="text-danger"></span>
                    </div>
                </div>

                <div class="row-3">
                    <div class="form-group">
                        <label class="form-label">Barangay</label>
                        <input asp-for="Barangay" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Street / House no.</label>
                        <input asp-for="Street" class="form-control" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Postal code</label>
                        <input asp-for="PostalCode" class="form-control" />
                    </div>
                </div>

                <p class="form-text mt-2 mb-1">
                    Forgot your password later? We'll email you a one-time reset link to <strong>@(string.IsNullOrWhiteSpace(Model.Email) ? "your inbox" : Model.Email)</strong>, so make sure your email is correct.
                </p>

                <button type="submit" class="btn btn-primary btn-lg btn-block">Create account</button>
            </form>
        </div>
    </div>
</section>
