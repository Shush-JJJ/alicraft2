@model ChangePasswordVm
@{
    ViewData["Title"] = "Change password";
}

<div class="section-head">
    <div>
        <h2>Change password</h2>
        <p class="lead">Pick a new password to secure your account.</p>
    </div>
    <a asp-action="Profile" class="btn btn-outline">← Back to profile</a>
</div>

<form asp-action="ChangePassword" method="post" autocomplete="off">
    @Html.AntiForgeryToken()
    <div class="grid-3">
        <div class="card"><div class="card-body">
            <h3 class="mt-0">Update your password</h3>
            <div asp-validation-summary="ModelOnly" class="alert alert-error mb-2" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

            <div class="form-group">
                <label class="form-label">Current password</label>
                <input asp-for="CurrentPassword" type="password" class="form-control" autocomplete="current-password" placeholder="Enter your current password"
                       data-no-space="true" />
                <span asp-validation-for="CurrentPassword" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label">New password</label>
                <input asp-for="NewPassword" type="password" class="form-control"
                       autocomplete="new-password"
                       minlength="8"
                       pattern="(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9])\S{8,}"
                       title="At least 8 characters with one uppercase letter, one number, one special character, and no spaces."
                       placeholder="At least 8 characters"
                       data-no-space="true" />
                <small class="form-text">8+ chars, 1 uppercase, 1 number, 1 special character, no spaces</small>
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Confirm new password</label>
                <input asp-for="ConfirmNewPassword" type="password" class="form-control"
                       autocomplete="new-password"
                       minlength="8"
                       placeholder="Re-type the new password"
                       data-no-space="true" />
                <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-lg mt-1">Save new password</button>
            <p class="form-text mt-2">Tip: use the eye icon to reveal what you typed.</p>
        </div></div>

        <div class="card"><div class="card-body">
            <h3 class="mt-0">Password requirements</h3>
            <ul style="margin:0;padding-left:1.1rem;line-height:1.8;">
                <li>At least <strong>8 characters</strong></li>
                <li>At least <strong>1 uppercase letter</strong> (A&ndash;Z)</li>
                <li>At least <strong>1 number</strong> (0&ndash;9)</li>
                <li>At least <strong>1 special character</strong> (e.g. ! @@ # $ %)</li>
                <li><strong>No spaces</strong> anywhere in the password.</li>
                <li>Don&rsquo;t reuse a password from another site.</li>
                <li>Forgot your current one? <a asp-action="ForgotPassword">Reset via email</a>.</li>
            </ul>
        </div></div>
    </div>
</form>
