@model ForgotPasswordVm
@{
    ViewData["Title"] = "Forgot password";
}

<section class="card">
    <div class="auth-shell" style="min-height:auto;">
        <div class="auth-hero">
            <img src="~/images/logo.png" alt="AliCraft" />
            <h1>Forgot your password?</h1>
            <p>No worries — we'll email you a one-time link to set a new one.</p>
        </div>
        <div class="auth-form-wrap">
            <form asp-action="ForgotPassword" method="post" class="auth-form">
                @Html.AntiForgeryToken()
                <h2>Reset your password</h2>
                <p class="lead">Enter the email you used to register and we'll send a reset link.</p>

                <div asp-validation-summary="ModelOnly" class="alert alert-error mb-2" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                <div class="form-group">
                    <label class="form-label">Account email</label>
                    <input asp-for="Email" class="form-control" placeholder="you@email.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary btn-lg btn-block">Send reset link</button>

                <p class="text-center mt-2 mb-0">
                    <a asp-action="Login">← Back to login</a>
                </p>
            </form>
        </div>
    </div>
</section>
