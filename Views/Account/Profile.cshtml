@inject CurrentUser CurrentUser
@model ProfileVm
@{
    ViewData["Title"] = "Profile";
    var avatar = ViewBag.AvatarPath as string;
}

<div class="section-head">
    <div>
        <h2>Profile settings</h2>
        <p class="lead">Manage your delivery address, contact info, and password.</p>
    </div>
    @if (!CurrentUser.IsAdmin)
    {
        <a asp-controller="Orders" asp-action="Index" class="btn btn-outline">Order history →</a>
    }
</div>

<form asp-action="Profile" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div class="grid-3">
        <div class="card"><div class="card-body">
            <h3 class="mt-0">Personal info</h3>
            <div asp-validation-summary="ModelOnly" class="alert alert-error mb-2" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

            <div class="row-2">
                <div class="form-group">
                    <label class="form-label">Full name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="form-group">
                    <label class="form-label">Phone</label>
                    <input asp-for="Phone" class="form-control"
                           type="tel"
                           inputmode="numeric"
                           maxlength="13"
                           pattern="(09|\+639|639)\d{9}"
                           title="Philippine mobile number (e.g. 09171234567 or +639171234567)."
                           placeholder="09171234567"
                           oninput="this.value=this.value.replace(/[^\d+]/g,'')" />
                    <small class="form-text">Digits only. Format: 09XXXXXXXXX or +639XXXXXXXXX</small>
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Email (read-only)</label>
                <input asp-for="Email" class="form-control" readonly />
            </div>

            <h3 class="mt-3">Delivery address</h3>
            <div class="row-2">
                <div class="form-group">
                    <label class="form-label">Province</label>
                    <select asp-for="Province" id="Province" class="form-control"
                            data-province="true" data-city-target="City"></select>
                </div>
                <div class="form-group">
                    <label class="form-label">City / Municipality</label>
                    <select asp-for="City" id="City" class="form-control" data-preset="@Model.City">
                        <option value="">Select city…</option>
                    </select>
                </div>
            </div>
            <div class="row-3">
                <div class="form-group">
                    <label class="form-label">Barangay</label>
                    <input asp-for="Barangay" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label">Street</label>
                    <input asp-for="Street" class="form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label">Postal code</label>
                    <input asp-for="PostalCode" class="form-control" />
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-lg mt-2">Save changes</button>
        </div></div>

        <div>
            <div class="card"><div class="card-body text-center">
                <h3 class="mt-0">Profile photo</h3>
                <div style="width:160px;height:160px;margin:0 auto 1rem;border-radius:50%;overflow:hidden;background:var(--ac-gradient);color:#fff;font-size:4rem;font-weight:800;display:flex;align-items:center;justify-content:center;">
                    @if (!string.IsNullOrEmpty(avatar))
                    {
                        <img src="@avatar" alt="avatar" style="width:100%;height:100%;object-fit:cover;" />
                    }
                    else
                    {
                        @Model.Name.Substring(0,1).ToUpper()
                    }
                </div>
                <label class="form-label">Upload new photo</label>
                <input asp-for="Avatar" type="file" class="form-control" accept="image/*" />
                <p class="form-text">JPG/PNG/WEBP up to 8 MB.</p>
            </div></div>

            <div class="card mt-2"><div class="card-body">
                <h3 class="mt-0">Account security</h3>
                <p class="text-muted mb-2" style="font-size:.9rem;">Change your password regularly to keep your account safe.</p>
                <a asp-action="ChangePassword" class="btn btn-outline btn-block">🔒 Change password</a>
            </div></div>
        </div>
    </div>
</form>
