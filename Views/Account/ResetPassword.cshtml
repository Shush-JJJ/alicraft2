@model ResetPasswordVm
@{
    ViewData["Title"] = "Reset password";
    var status = (string?)ViewBag.Status ?? "ok";
    var email = (string?)ViewBag.Email ?? "";
}

<section class="card">
    <div class="auth-shell" style="min-height:auto;">
        <div class="auth-hero">
            <img src="~/images/logo.png" alt="AliCraft" />
            <h1>@(status == "ok" ? "Choose a new password." : "Reset link issue")</h1>
            <p>@(status == "ok"
                ? "Almost done — pick something memorable but secure."
                : "We couldn't use that reset link. Request a new one to continue.")</p>
        </div>
        <div class="auth-form-wrap">
            @if (status == "ok")
            {
                <form asp-action="ResetPassword" method="post" class="auth-form" autocomplete="off">
                    @Html.AntiForgeryToken()
                    <input asp-for="Token" type="hidden" />
                    <h2>Reset password</h2>
                    @if (!string.IsNullOrEmpty(email))
                    {
                        <p class="lead">For <strong style="color:var(--ac-purple);">@email</strong></p>
                    }

                    <div asp-validation-summary="ModelOnly" class="alert alert-error mb-2" style="display:@(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    <div class="form-group">
                        <label class="form-label">New password</label>
                        <input asp-for="NewPassword" type="password" class="form-control" autocomplete="new-password" placeholder="At least 6 characters" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Confirm new password</label>
                        <input asp-for="ConfirmNewPassword" type="password" class="form-control" autocomplete="new-password" placeholder="Re-type the new password" />
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg btn-block">Set new password</button>
                    <p class="form-text text-center mt-2">Tip: use the eye icon to reveal what you typed.</p>
                </form>
            }
            else
            {
                <div class="auth-form text-center">
                    @if (status == "expired")
                    {
                        <div style="font-size:3.5rem;margin-bottom:.5rem;">⏰</div>
                        <h2>Link expired</h2>
                        <p class="lead">This reset link has expired.</p>
                        <p class="text-muted">Reset links are valid for 1 hour. Request a fresh one to continue.</p>
                    }
                    else
                    {
                        <div style="font-size:3.5rem;margin-bottom:.5rem;color:#ef4444;">✕</div>
                        <h2>Invalid link</h2>
                        <p class="lead">This reset link is invalid or has already been used.</p>
                        <p class="text-muted">If you still need to reset your password, request a fresh link.</p>
                    }
                    <a asp-action="ForgotPassword" class="btn btn-primary btn-lg btn-block mt-2">Send a new reset link</a>
                    <p class="text-center mt-2 mb-0">
                        <a asp-action="Login">← Back to login</a>
                    </p>
                </div>
            }
        </div>
    </div>
</section>
