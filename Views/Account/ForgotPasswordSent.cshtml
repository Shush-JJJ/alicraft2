@{
    ViewData["Title"] = "Check your email";
    var email = (string?)ViewBag.Email ?? "";
    var smtpReal = (bool)(ViewBag.SmtpConfigured ?? false);
}

<section class="card">
    <div class="auth-shell" style="min-height:auto;">
        <div class="auth-hero">
            <img src="~/images/logo.png" alt="AliCraft" />
            <h1>Almost there.</h1>
            <p>Click the link in the email we just sent to set a new password.</p>
        </div>
        <div class="auth-form-wrap">
            <div class="auth-form text-center">
                <div style="font-size:3.5rem;margin-bottom:.5rem;">📩</div>
                <h2>Check your inbox</h2>
                <p class="lead">
                    If an account exists for<br/>
                    <strong style="color:var(--ac-purple);">@email</strong><br/>
                    we just sent a password reset link.
                </p>
                <p class="text-muted">The link is valid for <strong>1 hour</strong>. If you don't see the email, check your spam folder.</p>

                @if (!smtpReal)
                {
                    <div class="alert alert-warning text-left mt-2">
                        <strong>Developer note:</strong> SMTP is not configured in <code>appsettings.json</code>.
                        The reset link was logged to the server console. Open the terminal where the app is running, find the line starting with <code>[EmailService]</code>, and copy the reset URL.
                    </div>
                }

                <p class="text-muted mt-3" style="font-size:.9rem;">
                    Didn't get the email? <a asp-action="ForgotPassword">Try again</a>.
                </p>

                <div class="mt-3">
                    <a asp-action="Login" class="btn btn-outline">Back to login</a>
                </div>
            </div>
        </div>
    </div>
</section>
